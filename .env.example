# Spotify integration (Authorization Code + PKCE — no client secret).
#
# Spotify rejects `localhost` as a redirect URI — use 127.0.0.1 for local.
#
# Dev redirect (put in .env.development so it is NOT baked into production builds):
#   VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback
#
# Production (registered in Spotify dashboard; used automatically when unset):
#   https://app.certchamps.ie/spotify/callback
#
# Optional production override (e.g. in CI / .env.production):
#   VITE_SPOTIFY_REDIRECT_URI=https://app.certchamps.ie/spotify/callback

VITE_SPOTIFY_CLIENT_ID=
